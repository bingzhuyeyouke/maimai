# ============================================
# 自媒体创作与多平台分发助手 - 配置模板
# ============================================
# 使用方法：复制本文件为 .env，然后填入真实值
#   cp .env.example .env
# ⚠️  .env 文件包含密钥，已被 .gitignore 排除，不会被提交

# ---------- 热点抓取 ----------
# 请求间隔（秒），避免被反爬
CRAWL_INTERVAL=60

# ---------- 数据库 ----------
# SQLite 数据库文件路径
DB_PATH=media_assistant.db

# ---------- AI 内容生成 ----------
# DeepSeek 接口（兼容 OpenAI SDK）
AI_API_KEY=sk-xxxxxxxx
AI_MODEL=deepseek-chat
AI_BASE_URL=https://api.deepseek.com

# ---------- 日志 ----------
# 日志级别：DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO

# ---------- 飞书表格（发帖模式） ----------
# 飞书开放平台应用凭证：https://open.feishu.cn/app
FEISHU_APP_ID=cli_xxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# 多维表格 token（从表格 URL 中获取，如 shtcnxxxxxxxxxxxxx）
FEISHU_SPREADSHEET_TOKEN=
# Sheet ID（表格中某个 sheet 的 ID）
FEISHU_SHEET_ID=

# ---------- 脉脉发帖 ----------
# 发帖间隔（秒），默认180秒(3分钟)
MAIMAI_POST_INTERVAL=180
